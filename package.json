{
	"name": "fancy-menus",
	"version": "0.0.0",
	"private": true,
	"description": "Declarative, accessible React menu library — build dropdowns, context menus, command palettes & popovers from typed config. TypeScript, headless, virtualized.",
	"keywords": [
		"react", "menu", "dropdown", "dropdown-menu", "context-menu",
		"command-palette", "popover", "select", "combobox", "tooltip",
		"headless", "accessible", "a11y", "declarative", "typescript",
		"floating-ui", "virtualized", "drag-and-drop", "react-component", "ui"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ra3orblade/fancy-menus.git"
	},
	"bugs": {
		"url": "https://github.com/ra3orblade/fancy-menus/issues"
	},
	"homepage": "https://github.com/ra3orblade/fancy-menus#readme",
	"workspaces": ["packages/*", "examples/*"],
	"scripts": {
		"dev": "bun --filter playground dev",
		"build": "bun --filter '*' build",
		"typecheck": "bun --filter '*' typecheck",
		"lint": "biome check .",
		"format": "biome format --write .",
		"test": "bun --filter '*' test"
	},
	"packageManager": "bun@1.1.0",
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"typescript": "^5.6.0",
		"@types/react": "^18.3.0",
		"@types/react-dom": "^18.3.0"
	},
	"overrides": {
		"ws": "^8.21.0"
	}
}
